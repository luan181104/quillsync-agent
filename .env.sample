# --- Google Gemini ---
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Filled in automatically the first time you run create_assistant.py,
# then reused by main.py on every subsequent (daily) run.
GEMINI_FILE_SEARCH_STORE_NAME=

GEMINI_MODEL=gemini-2.5-flash

# --- Zendesk / OptiSigns Help Center ---
ZENDESK_SUBDOMAIN=support.optisigns.com
ZENDESK_LOCALE=en-us

# --- Scraper behaviour ---
MAX_ARTICLES=100
ARTICLES_DIR=articles
STATE_FILE=state.json
